# Optional local credentials and runtime overrides.
#
# Copy this file to .env for local runs. Never commit .env.

# Global Fishing Watch API token.
GFW_TOKEN=replace-with-your-token

# CEDA archive access token, used for GEBCO OPeNDAP if required.
CEDA_TOKEN=replace-with-your-token

# Optional CEDA login credentials. If CEDA_TOKEN is not set, the GEBCO
# downloader can request a short-lived archive access token from CEDA's token API.
CEDA_USERNAME=replace-with-your-username
CEDA_PASSWORD=replace-with-your-password

# Optional config override used by src/riskscape/config.py.
# RISKCAPE_CONFIG=config.yaml
