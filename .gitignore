# Python bytecode and caches
__pycache__/*
*.py[cod]
*$py.class
*.so
.Python

# Packaging and build artifacts
/build/
/dist/
/downloads/
/*.egg-info/
*.egg-info/
*.egg
.eggs/
develop-eggs/
eggs/
parts/
sdist/
var/
wheels/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE and editor files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo

# Local environment and credentials
.env
.env.local

# OS metadata
.DS_Store
Thumbs.db

# Generated workflow outputs
/data/
/plots/
/outputs/
/logs/

# Downloaded reference data. Keep only the restoration instructions.
/reference/*
!/reference/README.md

# Local development scripts
scripts/dev/

# Keep organized script entry points trackable. These are intentionally named
# like generated root folders, so keep the exceptions explicit.
!scripts/data/
!scripts/data/**/*.py
!scripts/build/
!scripts/build/**/*.py
!scripts/plots/
!scripts/plots/**/*.py
!scripts/model/
!scripts/model/**/*.py
!scripts/qa/
!scripts/qa/**/*.py
!scripts/tools/
!scripts/tools/**/*.py

# Large/generated data artifacts anywhere in the tree
*.parquet
*.nc
*.zip

# Selected generated media under root plots
/plots/*.csv
/plots/**/*.csv
/plots/predictions/weekly_operator/*.mp4
/plots/predictions/weekly_operator/*.gif
/plots/predictions/weekly_operator/frames/
